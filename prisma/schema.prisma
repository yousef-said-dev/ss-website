generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model attendance {
  id           Int               @id @default(autoincrement())
  student_id   Int
  date         DateTime          @db.Date
  status       attendance_status
  created_at   DateTime?         @default(now()) @db.DateTime(0)
  updated_at   DateTime?         @default(now()) @db.DateTime(0)
  arrival_time String?           @db.VarChar(10)
  wa_sent      Boolean?          @default(false)
  students     students          @relation(fields: [student_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "attendance_ibfk_1")

  @@unique([student_id, date], map: "student_date")
}

model students {
  id          Int          @id @default(autoincrement())
  national_id String       @unique(map: "national_id") @db.VarChar(50)
  full_name   String       @db.VarChar(255)
  year        String?      @db.VarChar(50)
  class       String?      @db.VarChar(50)
  parent_id   Int?
  created_at  DateTime?    @default(now()) @db.DateTime(0)
  updated_at  DateTime?    @default(now()) @db.DateTime(0)
  attendance  attendance[]
  users       users?       @relation(fields: [parent_id], references: [id], onUpdate: Restrict, map: "students_ibfk_1")

  @@index([parent_id], map: "parent_id")
}

model users {
  id                   Int         @id @default(autoincrement())
  national_id          String      @unique(map: "national_id") @db.VarChar(255)
  name                 String?     @db.VarChar(255)
  phone                String?     @db.VarChar(20)
  email                String?     @db.VarChar(255)
  password             String      @db.VarChar(255)
  role                 users_role? @default(parent)
  must_change_password Boolean?    @default(true)
  created_at           DateTime?   @default(now()) @db.DateTime(0)
  updated_at           DateTime?   @default(now()) @db.DateTime(0)
  students             students[]
}

enum attendance_status {
  present
  late
  absent
}

enum users_role {
  admin
  staff
  parent
}

model rules {
  id          Int       @id @default(autoincrement())
  period_days Int
  type        String    @db.VarChar(50)
  frequency   String    @db.VarChar(50)
  created_at  DateTime? @default(now()) @db.DateTime(0)
  updated_at  DateTime? @default(now()) @db.DateTime(0)
}
